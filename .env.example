# ============================================================
# OGD Quality System - Environment Variables
# Copy this file to .env and fill in values
# ============================================================

# Database
POSTGRES_USER=ogd
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=ogdquality

# Redis
REDIS_PASSWORD=changeme_redis_password_here

# CKAN Source
CKAN_BASE_URL=https://saraburi.gdcatalog.go.th
CKAN_API_KEY=

# App Security
NEXTAUTH_SECRET=changeme_32chars_random_secret_here

# JWT Auth (สร้างด้วย: openssl rand -hex 32)
JWT_ACCESS_SECRET=changeme_access_secret_32chars_here
JWT_REFRESH_SECRET=changeme_refresh_secret_32chars_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Worker tuning
MAX_FILE_SIZE_MB=100
MAX_ROWS=200000
WORKER_CONCURRENCY=3
DOWNLOAD_TIMEOUT=60

# Cron schedule (crontab format) - default: every night at 2am
CRON_SYNC_SCHEDULE=0 2 * * *
CRON_SCAN_SCHEDULE=0 3 * * *

# Production domain (for nginx SSL)
DOMAIN=ogd.yourdomain.go.th

# Alert (Phase 2) - optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=
LINE_NOTIFY_TOKEN=
